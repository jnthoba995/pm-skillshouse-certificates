<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>PM Skillshouse OCR Lab</title>
  <style>
    :root {
      --bg: #f3f4f6;
      --card: #ffffff;
      --text: #1f2937;
      --muted: #6b7280;
      --border: #d1d5db;
      --accent: #f97316;
      --accent-soft: #fff7ed;
      --accent-border: #fdba74;
      --shadow: 0 10px 30px rgba(15, 23, 42, 0.08);
      --radius: 18px;
    }

    * { box-sizing: border-box; }

    body {
      margin: 0;
      font-family: Arial, Helvetica, sans-serif;
      background: var(--bg);
      color: var(--text);
    }

    .wrap {
      max-width: 1120px;
      margin: 0 auto;
      padding: 28px 20px 60px;
    }

    .card {
      background: var(--card);
      border: 1px solid #e5e7eb;
      border-radius: var(--radius);
      box-shadow: var(--shadow);
      padding: 28px;
      margin-bottom: 18px;
    }

    h1 {
      margin: 0 0 8px;
      font-size: 46px;
      line-height: 1.05;
      color: #1f2937;
    }

    h2 {
      margin: 0 0 10px;
      font-size: 28px;
      color: #1f2937;
    }

    p {
      margin: 0;
      color: var(--muted);
      line-height: 1.6;
      font-size: 16px;
    }

    .tag {
      display: inline-block;
      padding: 7px 12px;
      border-radius: 999px;
      background: var(--accent-soft);
      border: 1px solid var(--accent-border);
      color: #9a3412;
      font-size: 12px;
      font-weight: 700;
      margin-bottom: 14px;
    }

    .grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 18px;
    }

    .mini {
      padding: 18px;
      border: 1px solid #e5e7eb;
      border-radius: 14px;
      background: #fafafa;
    }

    .mini strong {
      display: block;
      margin-bottom: 8px;
      font-size: 15px;
      color: #111827;
    }

    .upload-box {
      border: 2px dashed var(--accent-border);
      background: var(--accent-soft);
      border-radius: 16px;
      padding: 22px;
    }

    .upload-box input[type="file"] {
      width: 100%;
      margin-top: 14px;
      padding: 12px;
      border: 1px solid var(--border);
      border-radius: 12px;
      background: #fff;
    }

    .actions {
      display: flex;
      gap: 14px;
      margin-top: 18px;
      flex-wrap: wrap;
    }

    button {
      border: none;
      border-radius: 12px;
      padding: 14px 18px;
      font-size: 15px;
      font-weight: 700;
      cursor: pointer;
    }

    .btn-primary {
      background: var(--accent);
      color: #fff;
    }

    .btn-secondary {
      background: #fff;
      color: #374151;
      border: 1px solid var(--border);
    }

    .status-box {
      margin-top: 18px;
      padding: 16px 18px;
      border-radius: 14px;
      background: #f9fafb;
      border: 1px solid #e5e7eb;
      color: #374151;
      font-size: 15px;
      line-height: 1.6;
    }

    .draft-table-wrap {
      overflow-x: auto;
      border: 1px solid #e5e7eb;
      border-radius: 14px;
      background: #fff;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      min-width: 860px;
    }

    th, td {
      padding: 14px 12px;
      border-bottom: 1px solid #e5e7eb;
      text-align: left;
      vertical-align: top;
      font-size: 14px;
    }

    th {
      background: #f9fafb;
      color: #374151;
      font-weight: 700;
    }

    td input, td select {
      width: 100%;
      padding: 10px 11px;
      border: 1px solid #d1d5db;
      border-radius: 10px;
      font-size: 14px;
      background: #fff;
    }

    .muted-note {
      margin-top: 12px;
      font-size: 13px;
      color: #6b7280;
    }

    .warning-box {
      border: 1px solid #fde68a;
      background: #fffbeb;
      color: #92400e;
      border-radius: 14px;
      padding: 16px 18px;
      margin-top: 18px;
      line-height: 1.6;
      font-size: 14px;
    }

    .preview-modal {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(15, 23, 42, 0.55);
      z-index: 9999;
      padding: 20px;
      align-items: center;
      justify-content: center;
    }

    .preview-modal-card {
      width: min(1200px, 100%);
      height: min(88vh, 900px);
      background: #ffffff;
      border-radius: 18px;
      box-shadow: 0 20px 60px rgba(15, 23, 42, 0.22);
      display: flex;
      flex-direction: column;
      overflow: hidden;
    }

    .preview-modal-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      padding: 16px 18px;
      border-bottom: 1px solid #e5e7eb;
      flex: 0 0 auto;
    }

    .preview-modal-title {
      margin: 0;
      font-size: 18px;
      font-weight: 700;
      color: #111827;
    }

    .preview-modal-body {
      flex: 1 1 auto;
      min-height: 0;
      overflow: auto;
      background: #f9fafb;
      padding: 14px;
      -webkit-overflow-scrolling: touch;
    }

    .preview-frame {
      width: 100%;
      height: 100%;
      min-height: 700px;
      border: none;
      background: #fff;
      border-radius: 12px;
    }

    .preview-image-wrap {
      min-width: max-content;
      min-height: 100%;
    }

    .preview-image {
      display: block;
      max-width: none;
      height: auto;
      border-radius: 12px;
      background: #fff;
      box-shadow: 0 6px 22px rgba(15, 23, 42, 0.08);
    }

    .split-workspace {
      display: grid;
      grid-template-columns: 1.1fr 1fr;
      gap: 18px;
      align-items: start;
    }

    .split-panel {
      background: #ffffff;
      border: 1px solid #e5e7eb;
      border-radius: 16px;
      overflow: hidden;
      min-height: 640px;
    }

    .split-panel-header {
      padding: 14px 16px;
      border-bottom: 1px solid #e5e7eb;
      background: #f9fafb;
      font-size: 15px;
      font-weight: 700;
      color: #111827;
    }

    .split-panel-body {
      height: 640px;
      overflow: auto;
      padding: 14px;
      background: #f9fafb;
      -webkit-overflow-scrolling: touch;
    }

    .split-preview-empty {
      color: #6b7280;
      font-size: 14px;
      line-height: 1.6;
      background: #fff;
      border: 1px dashed #d1d5db;
      border-radius: 12px;
      padding: 18px;
    }

    .split-preview-frame {
      width: 100%;
      height: 100%;
      min-height: 600px;
      border: none;
      background: #fff;
      border-radius: 12px;
    }

    .split-preview-image-wrap {
      min-width: max-content;
      min-height: 100%;
    }

    .split-preview-image {
      display: block;
      max-width: none;
      height: auto;
      border-radius: 12px;
      background: #fff;
      box-shadow: 0 6px 22px rgba(15, 23, 42, 0.08);
    }

    @media (max-width: 900px) {
      .split-workspace {
        grid-template-columns: 1fr;
      }

      .split-panel,
      .split-panel-body {
        min-height: auto;
        height: auto;
      }
      .grid {
        grid-template-columns: 1fr;
      }

      h1 {
        font-size: 36px;
      }
    }
  
    .draft-table tbody tr.confidence-high {
      background: #ffffff;
      transition: background 0.18s ease, box-shadow 0.18s ease;
    }

    .draft-table tbody tr.confidence-medium {
      background: rgba(245, 158, 11, 0.08);
      box-shadow: inset 3px 0 0 rgba(245, 158, 11, 0.45);
      transition: background 0.18s ease, box-shadow 0.18s ease;
    }

    .draft-table tbody tr.confidence-low {
      background: rgba(239, 68, 68, 0.10);
      box-shadow: inset 3px 0 0 rgba(239, 68, 68, 0.60);
      transition: background 0.18s ease, box-shadow 0.18s ease;
    }

    .draft-table tbody tr.confidence-medium:hover {
      background: rgba(245, 158, 11, 0.12);
    }

    .draft-table tbody tr.confidence-low:hover {
      background: rgba(239, 68, 68, 0.14);
    }

    .draft-table tbody tr.confidence-medium td.confidence-cell {
      font-weight: 600;
      color: #92400e;
    }

    .draft-table tbody tr.confidence-low td.confidence-cell {
      font-weight: 600;
      color: #991b1b;
    }

</style>
</head>
<body>
  <div class="wrap">
    <div class="card" style="text-align:center;">
      <img src="https://pmskillshouse.skillsbasedhub.co.za/logo.png" alt="PM Skillshouse Logo" style="height:70px; margin-bottom:12px;" />
      <div class="card">
      <div class="tag">SEPARATE OCR LAB</div>
      <h1>OCR Register Extraction Lab</h1>
      <p>
        This page is a separate prototype for scanned attendance register extraction.
        It is not yet linked to the live certificate workflow.
      </p>
    </div>

    <div class="card">
      <h2>What this lab will do</h2>
      <div class="grid">
        <div class="mini">
          <strong>Phase 1 goal</strong>
          <p>Upload a scanned register and convert it into a draft editable table.</p>
        </div>
        <div class="mini">
          <strong>Human review step</strong>
          <p>Let the user correct unclear names, ID numbers, contact numbers, and emails before export.</p>
        </div>
        <div class="mini">
          <strong>Storage direction</strong>
          <p>Keep scans temporary, then delete after a retention period once review/export is complete.</p>
        </div>
        <div class="mini">
          <strong>Later integration</strong>
          <p>When stable, connect reviewed rows into the existing certificate and export flow.</p>
        </div>
      </div>
    </div>

    <div class="card">
      <h2>Final Excel Export Structure</h2>
      <p>This OCR lab is being built around one final export format so both A3 and A4 extraction can feed the same output later.</p>
      <div class="draft-table-wrap" style="margin-top:16px;">
        <table style="min-width: 640px;">
          <thead>
            <tr>
              <th>Column Order</th>
              <th>Field Name</th>
              <th>Purpose</th>
            </tr>
          </thead>
          <tbody>
            <tr><td>1</td><td>Row Number</td><td>Register row reference</td></tr>
            <tr><td>2</td><td>Name</td><td>Participant first/given name</td></tr>
            <tr><td>3</td><td>Surname</td><td>Participant surname/family name</td></tr>
            <tr><td>4</td><td>ID Number / DOB</td><td>Identity number or date of birth field</td></tr>
            <tr><td>5</td><td>Contact Number</td><td>Participant phone/contact number</td></tr>
            <tr><td>6</td><td>Email Address</td><td>Participant email address</td></tr>
            <tr><td>7</td><td>Gender</td><td>Detected or confirmed gender selection</td></tr>
            <tr><td>8</td><td>Employment Status</td><td>Employed / Unemployed</td></tr>
            <tr><td>9</td><td>Credit Report Required</td><td>Yes / No field</td></tr>
            <tr><td>10</td><td>Financial Advice Required</td><td>Yes / No field</td></tr>
            <tr><td>11</td><td>Match Confidence</td><td>System confidence for OCR/matching</td></tr>
            <tr><td>12</td><td>Review Status</td><td>Needs review / Reviewed</td></tr>
          </tbody>
        </table>
      </div>
      <div class="muted-note">
        Later, A3 extraction will populate the base list first, and A4 forms will enrich or confirm the same rows before final Excel export.
      </div>
    </div>

    <div class="card">
      <h2>Upload scan or PDF</h2>
      <div class="upload-box">
        <p>Use this lab to test A3 and A4 register extraction without affecting the live prototype.</p>

        <div style="margin-top:18px;">
          <label style="font-weight:700; font-size:14px; color:#374151;">
            Register Type
          </label>
          <select id="registerType" style="width:100%; margin-top:8px; padding:12px; border:1px solid #d1d5db; border-radius:12px;">
            <option value="auto">Auto detect</option>
            <option value="liberty">Liberty Mind My Money Register</option>
            <option value="sanlam">Sanlam / Stokvel Register</option>
            <option value="template">Blank / Template Reference</option>
          </select>
        </div>

        <input id="ocrFile" type="file" accept=".pdf,image/*" />
        <div class="actions">
          <button id="analyzeBtn" class="btn-primary" type="button">Start OCR Analysis</button>
          <button id="previewScanBtn" class="btn-secondary" type="button">Preview Scan</button>
          <button id="exportDraftBtn" class="btn-secondary" type="button">Export Draft to Excel</button>
          <button id="resetBtn" class="btn-secondary" type="button">Reset Lab</button>
        </div>
        <div id="ocrStatus" class="status-box">
          Waiting for a scanned file. This lab will aim to detect rows first, then enable review and correction.
        </div>
        <div class="warning-box">
          OCR output should be treated as a draft. Handwritten scans may contain unclear letters and digits, so users must be able to review and correct the extracted data before export.
        </div>
      </div>
    </div>

    <div id="previewModal" class="preview-modal">
      <div class="preview-modal-card">
        <div class="preview-modal-header">
          <h3 class="preview-modal-title">Scan Preview</h3>
          <button id="closePreviewModalBtn" class="btn-secondary" type="button">Close</button>
        </div>
        <div id="previewModalBody" class="preview-modal-body"></div>
      </div>
    </div>

    <div class="card">
      <h2>Split Review Workspace</h2>
      <div class="split-workspace" style="margin-top:16px;">
        <div class="split-panel">
          <div class="split-panel-header">Scan Preview</div>
          <div id="splitPreviewBody" class="split-panel-body">
            <div class="split-preview-empty">
              Upload a scan or PDF, then use Preview Scan or Start OCR Analysis. The selected file will also appear here for side-by-side review.
            </div>
          </div>
        </div>

        <div class="split-panel">
          <div class="split-panel-header">Draft extracted rows</div>
          <div class="split-panel-body">
            <div class="draft-table-wrap">
              <table>
                <thead>
                  <tr>
                    <th>Row</th>
                    <th>Name</th>
                    <th>Surname</th>
                    <th>ID Number / DOB</th>
                    <th>Contact Number</th>
                    <th>Email Address</th>
                    <th>Gender</th>
                    <th>Employment Status</th>
                    <th>Credit Report Required</th>
                    <th>Financial Advice Required</th>
                    <th>Match Confidence</th>
                    <th>Review Status</th>
                  </tr>
                </thead>
                <tbody id="draftTableBody">
                  <tr>
                    <td>1</td>
                    <td><input value="" placeholder="Detected name" /></td>
                    <td><input value="" placeholder="Detected surname" /></td>
                    <td><input value="" placeholder="Detected ID number or date of birth" /></td>
                    <td><input value="" placeholder="Detected contact number" /></td>
                    <td><input value="" placeholder="Detected email address" /></td>
                    <td>
                      <select>
                        <option value="">Unknown</option>
                        <option>Male</option>
                        <option>Female</option>
                      </select>
                    </td>
                    <td>
                      <select>
                        <option value="">Unknown</option>
                        <option>Employed</option>
                        <option>Unemployed</option>
                      </select>
                    </td>
                    <td>
                      <select>
                        <option value="">Unknown</option>
                        <option>Yes</option>
                        <option>No</option>
                      </select>
                    </td>
                    <td>
                      <select>
                        <option value="">Unknown</option>
                        <option>Yes</option>
                        <option>No</option>
                      </select>
                    </td>
                    <td>
                      <select>
                        <option>Unknown</option>
                        <option>High</option>
                        <option>Medium</option>
                        <option>Low</option>
                      </select>
                    </td>
                    <td>
                      <select>
                        <option>Needs review</option>
                        <option>Reviewed</option>
                      </select>
                    </td>
                  </tr>
                </tbody>
              </table>
            </div>
            <div class="muted-note">
              This table represents the intended final Excel structure. Later, A3 extraction will populate the participant list first, then A4 matching will enrich these rows before export.
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script>
    const ocrFile = document.getElementById("ocrFile");
    const analyzeBtn = document.getElementById("analyzeBtn");
    const previewScanBtn = document.getElementById("previewScanBtn");
    const exportDraftBtn = document.getElementById("exportDraftBtn");
    const resetBtn = document.getElementById("resetBtn");
    const ocrStatus = document.getElementById("ocrStatus");
    const draftTableBody = document.getElementById("draftTableBody");
    const registerTypeSelect = document.getElementById("registerType");
    const splitPreviewBody = document.getElementById("splitPreviewBody");
    const previewModal = document.getElementById("previewModal");
    const previewModalBody = document.getElementById("previewModalBody");
    const closePreviewModalBtn = document.getElementById("closePreviewModalBtn");

    function buildDraftRow(row) {
      return `
        <tr>
          <td>${row.row || ""}</td>
          <td><input value="${row.name || ""}" placeholder="Detected name" /></td>
          <td><input value="${row.surname || ""}" placeholder="Detected surname" /></td>
          <td><input value="${row.idNumber || ""}" placeholder="Detected ID number or date of birth" /></td>
          <td><input value="${row.contact || ""}" placeholder="Detected contact number" /></td>
          <td><input value="${row.email || ""}" placeholder="Detected email address" /></td>
          <td>
            <select>
              <option value="" ${!row.gender ? "selected" : ""}>Unknown</option>
              <option ${row.gender === "Male" ? "selected" : ""}>Male</option>
              <option ${row.gender === "Female" ? "selected" : ""}>Female</option>
            </select>
          </td>
          <td>
            <select>
              <option value="" ${!row.employment ? "selected" : ""}>Unknown</option>
              <option ${row.employment === "Employed" ? "selected" : ""}>Employed</option>
              <option ${row.employment === "Unemployed" ? "selected" : ""}>Unemployed</option>
            </select>
          </td>
          <td>
            <select>
              <option value="" ${!row.creditReport ? "selected" : ""}>Unknown</option>
              <option ${row.creditReport === "Yes" ? "selected" : ""}>Yes</option>
              <option ${row.creditReport === "No" ? "selected" : ""}>No</option>
            </select>
          </td>
          <td>
            <select>
              <option value="" ${!row.financialAdvice ? "selected" : ""}>Unknown</option>
              <option ${row.financialAdvice === "Yes" ? "selected" : ""}>Yes</option>
              <option ${row.financialAdvice === "No" ? "selected" : ""}>No</option>
            </select>
          </td>
          <td>
            <select>
              <option ${row.confidence === "Unknown" ? "selected" : ""}>Unknown</option>
              <option ${row.confidence === "High" ? "selected" : ""}>High</option>
              <option ${row.confidence === "Medium" ? "selected" : ""}>Medium</option>
              <option ${row.confidence === "Low" ? "selected" : ""}>Low</option>
            </select>
          </td>
          <td>
            <select>
              <option ${row.review === "Needs review" ? "selected" : ""}>Needs review</option>
              <option ${row.review === "Reviewed" ? "selected" : ""}>Reviewed</option>
            </select>
          </td>
        </tr>
      `;
    }

    function getSimulatedRows(registerType) {
      if (registerType === "liberty") {
        return [
          { row: 1, name: "Kagiso", surname: "Molefe", idNumber: "9001015800087", contact: "0636613693", email: "kagiso@example.com", gender: "Male", employment: "Unemployed", creditReport: "Yes", financialAdvice: "No", confidence: "Medium", review: "Needs review" },
          { row: 2, name: "Thabo", surname: "Sitoesi", idNumber: "8705200058", contact: "0765595878", email: "", gender: "Male", employment: "Employed", creditReport: "No", financialAdvice: "Yes", confidence: "Low", review: "Needs review" },
          { row: 3, name: "Kanabo", surname: "Mose", idNumber: "900405647085", contact: "0870687944", email: "kanabo@example.com", gender: "Female", employment: "Unemployed", creditReport: "Yes", financialAdvice: "Yes", confidence: "Medium", review: "Needs review" }
        ];
      }

      if (registerType === "sanlam") {
        return [
          { row: 1, name: "Lerato", surname: "Nthebele", idNumber: "940101014083", contact: "0768577285", email: "", gender: "Female", employment: "", creditReport: "", financialAdvice: "", confidence: "Medium", review: "Needs review" },
          { row: 2, name: "Mpho", surname: "Moloi", idNumber: "820511023909", contact: "0736114922", email: "", gender: "Female", employment: "", creditReport: "", financialAdvice: "", confidence: "Low", review: "Needs review" },
          { row: 3, name: "Thato", surname: "Mokoena", idNumber: "900201011476", contact: "0616326350", email: "", gender: "Male", employment: "", creditReport: "", financialAdvice: "", confidence: "Low", review: "Needs review" }
        ];
      }

      if (registerType === "template") {
        return [
          { row: 1, name: "", surname: "", idNumber: "", contact: "", email: "", gender: "", employment: "", creditReport: "", financialAdvice: "", confidence: "Unknown", review: "Needs review" },
          { row: 2, name: "", surname: "", idNumber: "", contact: "", email: "", gender: "", employment: "", creditReport: "", financialAdvice: "", confidence: "Unknown", review: "Needs review" },
          { row: 3, name: "", surname: "", idNumber: "", contact: "", email: "", gender: "", employment: "", creditReport: "", financialAdvice: "", confidence: "Unknown", review: "Needs review" }
        ];
      }

      return [
        { row: 1, name: "Draft", surname: "Participant", idNumber: "Unknown", contact: "", email: "", gender: "", employment: "", creditReport: "", financialAdvice: "", confidence: "Medium", review: "Needs review" },
        { row: 2, name: "Second", surname: "Participant", idNumber: "Unknown", contact: "", email: "", gender: "", employment: "", creditReport: "", financialAdvice: "", confidence: "Low", review: "Needs review" },
        { row: 3, name: "Third", surname: "Participant", idNumber: "Unknown", contact: "", email: "", gender: "", employment: "", creditReport: "", financialAdvice: "", confidence: "Low", review: "Needs review" }
      ];
    }

    function renderSimulatedRows(registerType) {
      const rows = getSimulatedRows(registerType);
      draftTableBody.innerHTML = rows.map(buildDraftRow).join("");
    }

    function readDraftRowsForExport() {
      const rows = [];
      const trs = Array.from(draftTableBody.querySelectorAll("tr"));

      trs.forEach(function(tr) {
        const cells = tr.querySelectorAll("td");
        if (!cells.length) return;

        const getInputValue = function(index) {
          const input = cells[index] ? cells[index].querySelector("input") : null;
          return input ? String(input.value || "").trim() : "";
        };

        const getSelectValue = function(index) {
          const select = cells[index] ? cells[index].querySelector("select") : null;
          return select ? String(select.value || "").trim() : "";
        };

        rows.push({
          "Row Number": cells[0] ? String(cells[0].textContent || "").trim() : "",
          "Name": getInputValue(1),
          "Surname": getInputValue(2),
          "ID Number / DOB": getInputValue(3),
          "Contact Number": getInputValue(4),
          "Email Address": getInputValue(5),
          "Gender": getSelectValue(6),
          "Employment Status": getSelectValue(7),
          "Credit Report Required": getSelectValue(8),
          "Financial Advice Required": getSelectValue(9),
          "Match Confidence": getSelectValue(10),
          "Review Status": getSelectValue(11)
        });
      });

      return rows;
    }

    function exportDraftToExcel() {
      const rows = readDraftRowsForExport().filter(function(row) {
        return Object.keys(row).some(function(key) {
          return String(row[key] || "").trim() !== "";
        });
      });

      if (!rows.length) {
        ocrStatus.textContent = "There is no draft data to export yet.";
        return;
      }

      const worksheet = XLSX.utils.json_to_sheet(rows);
      const workbook = XLSX.utils.book_new();
      XLSX.utils.book_append_sheet(workbook, worksheet, "OCR Draft");

      const selectedType = registerTypeSelect ? registerTypeSelect.value : "ocr";
      const safeType = String(selectedType || "ocr").replace(/[^a-z0-9_-]+/gi, "_");
      const fileName = "ocr_draft_" + safeType + ".xlsx";

      XLSX.writeFile(workbook, fileName);
      ocrStatus.textContent = "Draft exported to Excel: " + fileName;
    }

    function renderSplitPreview() {
      if (!splitPreviewBody) {
        return;
      }

      if (!ocrFile || !ocrFile.files || !ocrFile.files[0]) {
        splitPreviewBody.innerHTML =
          '<div class="split-preview-empty">Upload a scan or PDF, then use Preview Scan or Start OCR Analysis. The selected file will also appear here for side-by-side review.</div>';
        return;
      }

      const file = ocrFile.files[0];
      const objectUrl = URL.createObjectURL(file);

      if ((file.type || "").includes("pdf") || file.name.toLowerCase().endsWith(".pdf")) {
        splitPreviewBody.innerHTML = '<iframe class="split-preview-frame" src="' + objectUrl + '"></iframe>';
      } else if ((file.type || "").startsWith("image/")) {
        splitPreviewBody.innerHTML =
          '<div class="split-preview-image-wrap"><img class="split-preview-image" src="' + objectUrl + '" alt="Uploaded split preview" /></div>';
      } else {
        splitPreviewBody.innerHTML = '<div class="split-preview-empty">Preview is not available for this file type yet.</div>';
      }
    }

    function openPreviewModal() {
      if (!ocrFile || !ocrFile.files || !ocrFile.files[0]) {
        ocrStatus.textContent = "Please choose a scanned file or PDF first.";
        return;
      }

      const file = ocrFile.files[0];
      const objectUrl = URL.createObjectURL(file);

      if (!previewModal || !previewModalBody) {
        return;
      }

      if ((file.type || "").includes("pdf") || file.name.toLowerCase().endsWith(".pdf")) {
        previewModalBody.innerHTML = '<iframe class="preview-frame" src="' + objectUrl + '"></iframe>';
      } else if ((file.type || "").startsWith("image/")) {
        previewModalBody.innerHTML =
          '<div class="preview-image-wrap"><img class="preview-image" src="' + objectUrl + '" alt="Uploaded scan preview" /></div>';
      } else {
        previewModalBody.innerHTML = '<div class="status-box">Preview is not available for this file type yet.</div>';
      }

      previewModal.style.display = "flex";
    }

    function closePreviewModal() {
      if (previewModal) {
        previewModal.style.display = "none";
      }
      if (previewModalBody) {
        previewModalBody.innerHTML = "";
      }
    }

    function resetLab() {
      if (ocrFile) ocrFile.value = "";
      if (splitPreviewBody) {
        splitPreviewBody.innerHTML =
          '<div class="split-preview-empty">Upload a scan or PDF, then use Preview Scan or Start OCR Analysis. The selected file will also appear here for side-by-side review.</div>';
      }
      if (ocrStatus) {
        ocrStatus.textContent =
          "Waiting for a scanned file. This lab will aim to detect rows first, then enable review and correction.";
      }
      if (draftTableBody) {
        draftTableBody.innerHTML = `
          <tr>
            <td>1</td>
            <td><input value="" placeholder="Detected name" /></td>
            <td><input value="" placeholder="Detected surname" /></td>
            <td><input value="" placeholder="Detected ID number or date of birth" /></td>
            <td><input value="" placeholder="Detected contact number" /></td>
            <td><input value="" placeholder="Detected email address" /></td>
            <td>
              <select>
                <option value="">Unknown</option>
                <option>Male</option>
                <option>Female</option>
              </select>
            </td>
            <td>
              <select>
                <option value="">Unknown</option>
                <option>Employed</option>
                <option>Unemployed</option>
              </select>
            </td>
            <td>
              <select>
                <option value="">Unknown</option>
                <option>Yes</option>
                <option>No</option>
              </select>
            </td>
            <td>
              <select>
                <option value="">Unknown</option>
                <option>Yes</option>
                <option>No</option>
              </select>
            </td>
            <td>
              <select>
                <option>Unknown</option>
                <option>High</option>
                <option>Medium</option>
                <option>Low</option>
              </select>
            </td>
            <td>
              <select>
                <option>Needs review</option>
                <option>Reviewed</option>
              </select>
            </td>
          </tr>
        `;
      }
    }

    function startAnalysis() {
      if (!ocrFile || !ocrFile.files || !ocrFile.files[0]) {
        ocrStatus.textContent = "Please choose a scanned file or PDF first.";
        return;
      }

      const file = ocrFile.files[0];
      const selectedType = registerTypeSelect ? registerTypeSelect.value : "auto";

      renderSplitPreview();
      renderSimulatedRows(selectedType);

      ocrStatus.textContent =
        "File loaded (" + file.name + "). Register type: " + selectedType +
        ". Simulated draft rows have been populated for review. Real OCR extraction will replace this step later.";
    }

    analyzeBtn.addEventListener("click", startAnalysis);
    if (previewScanBtn) previewScanBtn.addEventListener("click", openPreviewModal);
    if (exportDraftBtn) exportDraftBtn.addEventListener("click", exportDraftToExcel);
    resetBtn.addEventListener("click", resetLab);
    if (closePreviewModalBtn) closePreviewModalBtn.addEventListener("click", closePreviewModal);
    if (previewModal) {
      previewModal.addEventListener("click", function(event) {
        if (event.target === previewModal) {
          closePreviewModal();
        }
      });
    }
  
    function normalizeConfidence(value) {
      return String(value || "").trim().toLowerCase();
    }

    function getConfidenceClass(value) {
      const confidence = normalizeConfidence(value);
      if (confidence === "low") return "confidence-low";
      if (confidence === "medium") return "confidence-medium";
      return "confidence-high";
    }

    function applyConfidenceToRow(row) {
      if (!row) return;
      row.classList.remove("confidence-high", "confidence-medium", "confidence-low");

      const confidenceControl =
        row.querySelector('[data-field="matchConfidence"]') ||
        row.querySelector('.match-confidence') ||
        row.querySelector('select[name="matchConfidence"]') ||
        row.querySelector('select');

      if (!confidenceControl) return;

      const confidenceClass = getConfidenceClass(confidenceControl.value);
      row.classList.add(confidenceClass);

      const confidenceCell = confidenceControl.closest("td");
      if (confidenceCell) confidenceCell.classList.add("confidence-cell");
    }

    function applyConfidenceStylingToDraftTable() {
      const rows = document.querySelectorAll(".draft-table tbody tr");
      rows.forEach(applyConfidenceToRow);
    }

    document.addEventListener("change", function (event) {
      const target = event.target;
      if (!target) return;

      const isConfidenceField =
        target.matches('[data-field="matchConfidence"]') ||
        target.matches('.match-confidence') ||
        target.matches('select[name="matchConfidence"]');

      if (!isConfidenceField) return;

      const row = target.closest("tr");
      applyConfidenceToRow(row);
    });

</script>
</body>
</html>
