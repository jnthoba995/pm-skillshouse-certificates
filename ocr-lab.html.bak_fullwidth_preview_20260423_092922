    if (finalPreviewModal) finalPreviewModal.addEventListener("click", function (event) {
      if (event.target === finalPreviewModal) {
        finalPreviewModal.style.display = "none";
      }
    });

    function jumpToNextIssue() {
      const rows = Array.from(document.querySelectorAll('#reviewTableBody tr'));
      if (!rows.length) return;

      const current = document.querySelector('#reviewTableBody tr.issue-active');
      let startIndex = current ? rows.indexOf(current) + 1 : 0;

      rows.forEach((row) => row.classList.remove('issue-active'));

      for (let offset = 0; offset < rows.length; offset++) {
        const idx = (startIndex + offset) % rows.length;
        const row = rows[idx];
        const confidence = (row.getAttribute('data-confidence') || '').toLowerCase();
        const reviewSelect = row.querySelectorAll('select')[5];
        const reviewValue = reviewSelect ? (reviewSelect.value || '').toLowerCase() : '';

        if (confidence === 'low' || confidence === 'medium' || reviewValue === 'needs review') {
          row.classList.add('issue-active');
          row.scrollIntoView({ behavior: 'smooth', block: 'center' });
          const firstInput = row.querySelector('input, select');
          if (firstInput) firstInput.focus();
          return;
        }
      }
    }

    function updateRowReviewState(row) {
      if (!row) return;

      const inputs = Array.from(row.querySelectorAll('input'));
      const selects = Array.from(row.querySelectorAll('select'));
      const reviewSelect = selects[5];
      const requiredInputs = inputs.slice(0, 6);
      const requiredSelects = selects.slice(0, 4);

      const inputOk = requiredInputs.every((input) => {
        const value = (input.value || '').trim().toLowerCase();
        const placeholder = ((input.getAttribute('placeholder') || '')).trim().toLowerCase();
        return value && value !== placeholder;
      });

      const selectOk = requiredSelects.every((select) => {
        const value = (select.value || '').trim().toLowerCase();
        return value && value !== 'unknown';
      });

      if (reviewSelect) {
        if (inputOk && selectOk) {
          row.setAttribute('data-reviewed','true');
        } else {
          row.removeAttribute('data-reviewed');
        }
        if (inputOk && selectOk) {
          reviewSelect.value = 'Reviewed';
        } else if (reviewSelect.value === 'Reviewed') {
          reviewSelect.value = 'Needs review';
        }
      }
    }

    function bindAutoReview() {
      const rows = Array.from(document.querySelectorAll('#reviewTableBody tr'));
      rows.forEach((row) => {
        const fields = row.querySelectorAll('input, select');
        fields.forEach((field) => {
          field.addEventListener('input', function () {
            updateRowReviewState(row);
          });
          field.addEventListener('change', function () {
            updateRowReviewState(row);
          });
        });
        updateRowReviewState(row);
      });
    }

    function getFocusableIssueFields() {
      const fields = Array.from(document.querySelectorAll('#reviewTableBody input, #reviewTableBody select'));
      return fields.filter((field) => {
        const value = (field.value || '').trim().toLowerCase();
        const placeholder = ((field.getAttribute('placeholder') || '')).trim().toLowerCase();
        if (field.tagName === 'SELECT') {
          return !value || value === 'unknown';
        }
        return !value || value === placeholder;
      });
    }

    function focusNextEmptyField() {
      const fields = getFocusableIssueFields();
      if (!fields.length) return;

      const active = document.activeElement;
      let startIndex = active ? fields.indexOf(active) + 1 : 0;
      if (startIndex < 0) startIndex = 0;

      const nextField = fields[startIndex % fields.length];
      const row = nextField.closest('tr');

      document.querySelectorAll('#reviewTableBody tr').forEach((tr) => tr.classList.remove('issue-active'));
      if (row) {
        row.classList.add('issue-active');
        row.scrollIntoView({ behavior: 'smooth', block: 'center' });
      }

      nextField.focus();
    }

    if (focusEmptyBtn) focusEmptyBtn.addEventListener('click', focusNextEmptyField);
    if (jumpIssueBtn) jumpIssueBtn.addEventListener('click', jumpToNextIssue);


