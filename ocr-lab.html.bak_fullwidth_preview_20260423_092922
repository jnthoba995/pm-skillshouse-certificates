    function startAnalysis() {
      if (!ocrFile || !ocrFile.files || !ocrFile.files[0]) {
        ocrStatus.textContent = "Please choose a scanned file or PDF first.";
        return;
      }

      const file = ocrFile.files[0];
      const selectedType = registerTypeSelect ? registerTypeSelect.value : "auto";

      
if (reviewTableBody) reviewTableBody.innerHTML = "";
window.__OCR_ROWS__ = rows || [];
renderSimulatedRows(window.__OCR_ROWS__);

setTimeout(() => {
