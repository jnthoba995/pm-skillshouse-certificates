<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>PM Skillshouse OCR Lab</title>
  <style>
    :root {
      --bg: #f3f4f6;
      --card: #ffffff;
      --text: #1f2937;
      --muted: #6b7280;
      --border: #d1d5db;
      --accent: #f97316;
      --accent-soft: #fff7ed;
      --accent-border: #fdba74;
      --shadow: 0 10px 30px rgba(15, 23, 42, 0.08);
      --radius: 18px;
    }

    * { box-sizing: border-box; }

    body {
      margin: 0;
      font-family: Arial, Helvetica, sans-serif;
      background: var(--bg);
      color: var(--text);
    }

    .wrap {
      max-width:100%;
      margin: 0 auto;
      padding: 28px 20px 60px;
    }

    .card {
      background: var(--card);
      border: 1px solid #e5e7eb;
      border-radius: var(--radius);
      box-shadow: var(--shadow);
      padding: 28px;
      margin-bottom: 18px;
    }

    h1 {
      margin: 0 0 8px;
      font-size: 46px;
      line-height: 1.05;
      color: #1f2937;
    }

    h2 {
      margin: 0 0 10px;
      font-size: 28px;
      color: #1f2937;
    }

    p {
      margin: 0;
      color: var(--muted);
      line-height: 1.6;
      font-size: 16px;
    }

    .tag {
      display: inline-block;
      padding: 7px 12px;
      border-radius: 999px;
      background: var(--accent-soft);
      border: 1px solid var(--accent-border);
      color: #9a3412;
      font-size: 12px;
      font-weight: 700;
      margin-bottom: 14px;
    }

    .grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 18px;
    }

    .mini {
      padding: 18px;
      border: 1px solid #e5e7eb;
      border-radius: 14px;
      background: #fafafa;
    }

    .mini strong {
      display: block;
      margin-bottom: 8px;
      font-size: 15px;
      color: #111827;
    }

    .upload-box {
      border: 2px dashed var(--accent-border);
      background: var(--accent-soft);
      border-radius: 16px;
      padding: 22px;
    }

    .upload-box input[type="file"] {
      width: 100%;
      margin-top: 14px;
      padding: 12px;
      border: 1px solid var(--border);
      border-radius: 12px;
      background: #fff;
    }

    .actions {
      display: flex;
      gap: 14px;
      margin-top: 18px;
      flex-wrap: wrap;
    }

    button {
      border: none;
      border-radius: 12px;
      padding: 14px 18px;
      font-size: 15px;
      font-weight: 700;
      cursor: pointer;
    }

    .btn-primary {
      background: var(--accent);
      color: #fff;
    }

    .btn-secondary {
      background: #fff;
      color: #374151;
      border: 1px solid var(--border);
    }

    .status-box {
      margin-top: 18px;
      padding: 16px 18px;
      border-radius: 14px;
      background: #f9fafb;
      border: 1px solid #e5e7eb;
      color: #374151;
      font-size: 15px;
      line-height: 1.6;
    }

    .draft-table-wrap {
      overflow-x: auto;
      border: 1px solid #e5e7eb;
      border-radius: 14px;
      background: #fff;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      min-width: 860px;
    }

    th, td {
      padding: 14px 12px;
      border-bottom: 1px solid #e5e7eb;
      text-align: left;
      vertical-align: top;
      font-size: 14px;
    }

    th {
      background: #f9fafb;
      color: #374151;
      font-weight: 700;
    }

    td input, td select {
      width: 100%;
      padding: 10px 11px;
      border: 1px solid #d1d5db;
      border-radius: 10px;
      font-size: 14px;
      background: #fff;
    }

    .muted-note {
      margin-top: 12px;
      font-size: 13px;
      color: #6b7280;
    }

    .warning-box {
      border: 1px solid #fde68a;
      background: #fffbeb;
      color: #92400e;
      border-radius: 14px;
      padding: 16px 18px;
      margin-top: 18px;
      line-height: 1.6;
      font-size: 14px;
    }

    .preview-modal {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(15, 23, 42, 0.55);
      z-index: 9999;
      padding: 20px;
      align-items: center;
      justify-content: center;
    }

    .preview-modal-card {
      width: min(1200px, 100%);
      height: min(88vh, 900px);
      background: #ffffff;
      border-radius: 18px;
      box-shadow: 0 20px 60px rgba(15, 23, 42, 0.22);
      display: flex;
      flex-direction: column;
      overflow: hidden;
    }

    .preview-modal-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      padding: 16px 18px;
      border-bottom: 1px solid #e5e7eb;
      flex: 0 0 auto;
    }

    .preview-modal-title {
      margin: 0;
      font-size: 18px;
      font-weight: 700;
      color: #111827;
    }

    .preview-modal-body {
      flex: 1 1 auto;
      min-height: 0;
      overflow: auto;
      background: #f9fafb;
      padding: 14px;
      -webkit-overflow-scrolling: touch;
    }

    .preview-frame {
      width: 100%;
      height: 100%;
      min-height: 700px;
      border: none;
      background: #fff;
      border-radius: 12px;
    }

    .preview-image-wrap {
      min-width: max-content;
      min-height: 100%;
    }

    .preview-image {
      display: block;
      max-width: none;
      height: auto;
      border-radius: 12px;
      background: #fff;
      box-shadow: 0 6px 22px rgba(15, 23, 42, 0.08);
    }

    

    

    

    

    

    

    

    

    @media (max-width: 900px) {
      

      
      .grid {
        grid-template-columns: 1fr;
      }

      h1 {
        font-size: 36px;
      }
    }
  
    .draft-table tbody tr.confidence-high {
      background: #ffffff;
      transition: background 0.18s ease, box-shadow 0.18s ease;
    }

    .draft-table tbody tr.confidence-medium {
  background: rgba(245, 158, 11, 0.10);
  border-left: 4px solid #f59e0b;
}
      background: rgba(245, 158, 11, 0.08);
      box-shadow: inset 3px 0 0 rgba(245, 158, 11, 0.45);
      transition: background 0.18s ease, box-shadow 0.18s ease;
    }

    .draft-table tbody tr.confidence-low {
  background: rgba(239, 68, 68, 0.12);
  border-left: 4px solid #ef4444;
}
      background: rgba(239, 68, 68, 0.10);
      box-shadow: inset 3px 0 0 rgba(239, 68, 68, 0.60);
      transition: background 0.18s ease, box-shadow 0.18s ease;
    }

    .draft-table tbody tr.confidence-medium:hover {
      background: rgba(245, 158, 11, 0.12);
    }

    .draft-table tbody tr.confidence-low:hover {
      background: rgba(239, 68, 68, 0.14);
    }

    .draft-table tbody tr.confidence-medium td.confidence-cell {
      font-weight: 600;
      color: #92400e;
    }

    .draft-table tbody tr.confidence-low td.confidence-cell {
      font-weight: 600;
      color: #991b1b;
    }


    .draft-table tbody tr.confidence-low {
  background: rgba(239, 68, 68, 0.12);
  border-left: 4px solid #ef4444;
}
      background: rgba(239, 68, 68, 0.10);
      box-shadow: inset 3px 0 0 rgba(239, 68, 68, 0.60), 0 0 0 1px rgba(239, 68, 68, 0.15);
      position: relative;
    }

    .confidence-badge {
      display: inline-block;
      margin-left: 6px;
      padding: 2px 8px;
      font-size: 11px;
      border-radius: 999px;
      background: rgba(239, 68, 68, 0.12);
      color: #991b1b;
      font-weight: 600;
    }


    .lab-hidden {
      display: none;
    }

    .lab-toggle-btn {
      display: inline-block;
      margin-bottom: 16px;
      padding: 8px 14px;
      border-radius: 999px;
      font-size: 13px;
      font-weight: 600;
      background: #111827;
      color: #ffffff;
      cursor: pointer;
    }

    .workspace-expanded {
      max-width:100%;
      width: 95%;
    }

    


