    }

    if (analyzeBtn) analyzeBtn.addEventListener("click", startAnalysis);
    if (exportDraftBtn) exportDraftBtn.addEventListener("click", downloadSheetExcel);

    
    

    function collectSheetRows() {
      const rows = Array.from(document.querySelectorAll("#reviewTableBody tr:not([style*=\"display: none\"])"));
      return rows.map((tr, index) => {
        const inputs = Array.from(tr.querySelectorAll("input"));
        const selects = Array.from(tr.querySelectorAll("select"));
        const val = (el) => el ? (el.value || "").trim() : "";
        return {
          number: index + 1,
          row: val(inputs[0]),
          name: val(inputs[1]),
          surname: val(inputs[2]),
          idNumber: val(inputs[3]),
          contact: val(inputs[4]),
          email: val(inputs[5]),
          gender: val(selects[0]),
          employment: val(selects[1]),
          creditReport: val(selects[2]),
          financialAdvice: val(selects[3]),
          confidence: val(selects[4]),
          reviewStatus: val(selects[5])
        };
      });
    }

    function downloadSheetExcel() {
      const rows = collectSheetRows();
      if (!rows.length) {
        ocrStatus.textContent = "Nothing to export yet.";
        return;
      }

      const headers = [
        
        "Row",
        "Name",
        "Surname",
        "ID Number / DOB",
        "Contact Number",
        "Email Address",
        "Gender",
        "Employment",
        "Credit Report",
        "Financial Advice",
        "Confidence",
        "Review Status"
      ];

      const escapeCell = (value) => {
        const text = String(value == null ? "" : value).replace(/"/g, '""');
        return '"' + text + '"';
      };

      const csv = [
        headers.map(escapeCell).join(","),
        ...rows.map((row) => [
          
          row.row,
          row.name,
          row.surname,
          row.idNumber,
          row.contact,
          row.email,
          row.gender,
          row.employment,
          row.creditReport,
          row.financialAdvice,
          row.confidence,
          row.reviewStatus
        ].map(escapeCell).join(","))
      ].join("\n");

      const blob = new Blob([csv], { type: "text/csv;charset=utf-8;" });
      const url = URL.createObjectURL(blob);
      const link = document.createElement("a");
      const stamp = new Date().toISOString().slice(0,19).replace(/[:T]/g, "-");
      link.href = url;
      link.download = "ocr-register-draft-" + stamp + ".csv";
      document.body.appendChild(link);
      link.click();
      document.body.removeChild(link);
      URL.revokeObjectURL(url);
      ocrStatus.textContent = "Draft exported from the reviewed sheet.";
    }

