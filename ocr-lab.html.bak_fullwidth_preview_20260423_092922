    function buildDraftRow(row, index) {
      const confidence = (row.confidence || "high").toLowerCase();
      const confidenceClass = confidence === "low" ? "confidence-low" : confidence === "medium" ? "confidence-medium" : "confidence-high";
      const reviewStatus = row.reviewStatus || (confidence === "low" ? "Needs review" : "Draft");
      return `
        <tr class="${confidenceClass}" data-confidence="${confidence}" style="border-bottom:1px solid #f1f5f9;">
          
          <td style="padding:10px;"><input style="width:100%; padding:10px; font-size:14px; border-bottom:1px solid #e5e7eb; border-radius:8px;" value="${row.row || ""}" placeholder="Row" /></td>
          <td style="padding:10px;"><input style="width:100%; padding:10px; font-size:14px; border-bottom:1px solid #e5e7eb; border-radius:8px;" value="${row.name || ""}" placeholder="Name" /></td>
          <td style="padding:10px;"><input style="width:100%; padding:10px; font-size:14px; border-bottom:1px solid #e5e7eb; border-radius:8px;" value="${row.surname || ""}" placeholder="Surname" /></td>
          <td style="padding:10px;"><input style="width:100%; padding:10px; font-size:14px; border-bottom:1px solid #e5e7eb; border-radius:8px;" value="${row.idNumber || ""}" placeholder="ID number or DOB" /></td>
          <td style="padding:10px;"><input style="width:100%; padding:10px; font-size:14px; border-bottom:1px solid #e5e7eb; border-radius:8px;" value="${row.contact || ""}" placeholder="Contact number" /></td>
          <td style="padding:10px;"><input style="width:100%; padding:10px; font-size:14px; border-bottom:1px solid #e5e7eb; border-radius:8px;" value="${row.email || ""}" placeholder="Email address" /></td>
          <td style="padding:10px;">
            <select style="width:100%; padding:10px; font-size:14px; border-bottom:1px solid #e5e7eb; border-radius:8px;">
              <option value="" ${!row.gender ? "selected" : ""}>Unknown</option>
              <option value="Male" ${row.gender === "Male" ? "selected" : ""}>Male</option>
              <option value="Female" ${row.gender === "Female" ? "selected" : ""}>Female</option>
            </select>
          </td>
          <td style="padding:10px;">
            <select style="width:100%; padding:10px; font-size:14px; border-bottom:1px solid #e5e7eb; border-radius:8px;">
              <option value="" ${!row.employment ? "selected" : ""}>Unknown</option>
              <option value="Employed" ${row.employment === "Employed" ? "selected" : ""}>Employed</option>
              <option value="Unemployed" ${row.employment === "Unemployed" ? "selected" : ""}>Unemployed</option>
            </select>
          </td>
          <td style="padding:10px;">
            <select style="width:100%; padding:10px; font-size:14px; border-bottom:1px solid #e5e7eb; border-radius:8px;">
              <option value="" ${!row.creditReport ? "selected" : ""}>Unknown</option>
              <option value="Yes" ${row.creditReport === "Yes" ? "selected" : ""}>Yes</option>
              <option value="No" ${row.creditReport === "No" ? "selected" : ""}>No</option>
            </select>
          </td>
          <td style="padding:10px;">
            <select style="width:100%; padding:10px; font-size:14px; border-bottom:1px solid #e5e7eb; border-radius:8px;">
              <option value="" ${!row.financialAdvice ? "selected" : ""}>Unknown</option>
              <option value="Yes" ${row.financialAdvice === "Yes" ? "selected" : ""}>Yes</option>
              <option value="No" ${row.financialAdvice === "No" ? "selected" : ""}>No</option>
            </select>
          </td>
          <td style="padding:10px;">
            <select style="width:100%; padding:10px; font-size:14px; border-bottom:1px solid #e5e7eb; border-radius:8px;">
              <option value="high" ${confidence === "high" ? "selected" : ""}>High</option>
              <option value="medium" ${confidence === "medium" ? "selected" : ""}>Medium</option>
              <option value="low" ${confidence === "low" ? "selected" : ""}>Low</option>
            </select>
          </td>
          <td style="padding:10px;">
            <select style="width:100%; padding:10px; font-size:14px; border-bottom:1px solid #e5e7eb; border-radius:8px;">
              <option value="Draft" ${reviewStatus === "Draft" ? "selected" : ""}>Draft</option>
              <option value="Needs review" ${reviewStatus === "Needs review" ? "selected" : ""}>Needs review</option>
              <option value="Reviewed" ${reviewStatus === "Reviewed" ? "selected" : ""}>Reviewed</option>
            </select>
          </td>
        </tr>
      `;
    }

    
function applyFieldLevelIssues() {
  const rows = document.querySelectorAll("#reviewTableBody tr:not([style*=\"display: none\"])");

  rows.forEach((row) => {
    const inputs = row.querySelectorAll("input");
    const selects = row.querySelectorAll("select");

    inputs.forEach((input) => {
      const value = (input.value || "").trim().toLowerCase();
      const placeholder = (input.placeholder || "").toLowerCase();

      const isEmpty = !value || value === placeholder;

      if (isEmpty) {
        input.style.border = "2px solid #ef4444";
        input.style.background = "#fff5f5";
      } else {
        input.style.border = "1px solid #d1d5db";
        input.style.background = "#ffffff";
      }
    });

    selects.forEach((select) => {
      const value = (select.value || "").toLowerCase();

      if (!value || value === "unknown") {
        select.style.border = "2px solid #ef4444";
        select.style.background = "#fff5f5";
      } else {
        select.style.border = "1px solid #d1d5db";
        select.style.background = "#ffffff";
      }
    });
  });
}
